# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
MONGO_URI=mongodb://localhost:27017/eventsphere

# JWT configuration
JWT_SECRET=super_secret_jwt_signing_key_change_me_in_production
JWT_EXPIRES_IN=7d

# AWS Credentials (Optional in local development; mock fallback will engage if not provided)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=eventsphere-media-storage
CLOUDFRONT_URL=
